{
  "name": "agentic-tools",
  "version": "1.0.0",
  "description": "Unified AI-powered tools: Resume Editor, Art Inspiration, and Tanaga Poetry Agent",
  "main": "server.bundle.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "esbuild server.ts --bundle --platform=node --target=node20 --format=cjs --outfile=server.bundle.js --external:@xenova/transformers",
    "start": "node server.bundle.js",
    "rag:index": "tsx src/scripts/buildIndex.ts all",
    "rag:index:home": "tsx src/scripts/buildIndex.ts home",
    "rag:index:resume": "tsx src/scripts/buildIndex.ts resume",
    "rag:index:art": "tsx src/scripts/buildIndex.ts art",
    "rag:index:tanaga": "tsx src/scripts/buildIndex.ts tanaga",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "esbuild": "^0.25.3",
    "express": "^4.21.2",
    "mammoth": "^1.9.1",
    "pdf-parse": "^1.1.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.0",
    "@types/pdf-parse": "^1.1.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
