# ── Mistral AI ────────────────────────────────────────────────
# Single API key shared by all four apps
MISTRAL_API_KEY=your_mistral_api_key

# ── Agent IDs ─────────────────────────────────────────────────
# Each app uses its own dedicated Mistral agent
HOME_AGENT_ID=agent_xxxxxxxxxxxxxxxxxxxxxxxx
RESUME_AGENT_ID=agent_xxxxxxxxxxxxxxxxxxxxxxxx
ART_AGENT_ID=agent_xxxxxxxxxxxxxxxxxxxxxxxx
TANAGA_AGENT_ID=agent_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
# Production URL (used for CORS restriction). Leave blank in development.
APP_URL=https://yourdomain.com

# ── RAG Configuration (optional — defaults shown) ─────────────
RAG_TOP_K=4
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
